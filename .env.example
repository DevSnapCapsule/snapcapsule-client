# SnapCapsule API configuration
# Copy to .env for local reference (iOS reads proxy URL from the app / Config.plist)

# Optional override if your Cloud Run URL differs from the default in the app
# GEMINI_PROXY_URL=https://gemini-proxy-937348762913.europe-west1.run.app

# Vision (server-side via Cloud Run proxy — no key needed in the app)
GOOGLE_VISION_API_KEY=YOUR_GOOGLE_CLOUD_VISION_API_KEY_HERE
