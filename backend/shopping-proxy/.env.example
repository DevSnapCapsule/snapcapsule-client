# SnapCapsule Shopping Proxy — local reference only (not read by Cloud Run).
# Copy to .env for local development. Production secrets come from Secret Manager.

EBAY_CLIENT_ID=YOUR_EBAY_CLIENT_ID_HERE
EBAY_CLIENT_SECRET=YOUR_EBAY_CLIENT_SECRET_HERE
EBAY_ENVIRONMENT=sandbox
AFFILIATE_ENABLED=false
CACHE_TTL_MINUTES=30

# Optional — only needed when monetization is enabled
# EBAY_CAMPAIGN_ID=YOUR_EBAY_CAMPAIGN_ID_HERE
